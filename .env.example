# ─────────────────────────────────────────────
# Task Management App — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=taskapp
POSTGRES_PASSWORD=taskapp_secret
POSTGRES_DB=taskappdb
POSTGRES_PORT=5432

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret
KEYCLOAK_PORT=8080

# Backend
BACKEND_PORT=5000

# Frontend
FRONTEND_PORT=4200
